{
    "name": "blogme/blogme",
    "description": "Blogme: PHP refactor of tunalog with SQLite and Alpine+TocasUI frontend",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-json": "*",
        "erusev/parsedown": "^1.7.4",
        "latte/latte": "^3.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Blogme\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Blogme\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
