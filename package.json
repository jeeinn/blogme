{
  "name": "blogme-admin-editor",
  "private": true,
  "version": "1.0.0",
  "description": "Build tooling for blogme admin Milkdown Crepe editor assets",
  "scripts": {
    "build:admin-editor": "esbuild public/admin/assets/editor-crepe-src.js --bundle --format=esm --target=es2020 --minify --outfile=public/admin/assets/editor-crepe.js --loader:.css=css --loader:.woff2=file --loader:.woff=file --loader:.ttf=file --loader:.otf=file --loader:.eot=file --loader:.svg=file --loader:.png=file --asset-names=editor-assets/[name]-[hash]",
    "build:theme-mermaid": "esbuild public/themes/default/assets/mermaid-page-src.js --bundle --format=esm --target=es2020 --minify --outfile=public/themes/default/assets/mermaid-page.js",
    "compress": "node scripts/compress.js",
    "build": "npm run build:admin-editor && npm run build:theme-mermaid && npm run compress"
  },
  "devDependencies": {
    "@milkdown/crepe": "7.18.0",
    "esbuild": "^0.25.9"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "mermaid": "^11.13.0"
  }
}
